{
  "name": "radar-precos-mcp",
  "version": "1.0.0",
  "description": "MCP server para pesquisa de precos em contratacoes publicas - IN SEGES/ME 65/2021",
  "keywords": ["mcp", "pncp", "licitacao", "pesquisa-precos", "compras-publicas"],
  "author": "Contribuidores do projeto",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
